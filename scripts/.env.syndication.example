# Content Pipeline API Keys
# Copy this file to .env.syndication and fill in your keys

# ── Content Generation ──
# KoalaWriter — https://koala.sh → Account → API Key
KOALA_API_KEY=

# Search Atlas — already configured in Claude MCP
SEARCHATLAS_API_KEY=

# ── Syndication Platforms ──
# Dev.to — https://dev.to/settings/extensions → Generate API Key
DEVTO_API_KEY=

# Hashnode — https://hashnode.com/settings/developer
HASHNODE_TOKEN=
HASHNODE_PUBLICATION_ID=

# Medium — https://medium.com/me/settings → Integration tokens
MEDIUM_TOKEN=

# Tumblr — https://www.tumblr.com/oauth/apps
TUMBLR_TOKEN=
TUMBLR_BLOG_NAME=
